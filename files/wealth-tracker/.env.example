# ============================================================
#  WEALTH TRACKER — Variables d'environnement
#  Copier ce fichier en .env.local et remplir les valeurs
#  ⚠ Ne jamais committer .env.local dans git
# ============================================================

# ── Binance ──────────────────────────────────────────────────
# Créer sur : https://www.binance.com/fr/my/settings/api-management
# Permissions requises : ✅ Read  ❌ Trade  ❌ Withdraw
# Restriction IP recommandée : mettre l'IP de ton serveur

BINANCE_API_KEY=TBD
BINANCE_SECRET_KEY=TBD

